#!/usr/bin/env bash
set -euo pipefail

DEFAULT_HOST="192.168.144.111"
CONFIG_DIR="$HOME/.config/ssha"
CONFIG="$CONFIG_DIR/config.json"
SSH_OPTS=(-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR)

usage() {
    echo "Usage: ssha [options] <user> [command...]"
    echo ""
    echo "Options:"
    echo "  -u, --user <user>   SSH user"
    echo "  -h, --host <host>   Host IP (default: $DEFAULT_HOST)"
    echo "  --setup             Re-run key selection"
    echo ""
    echo "Examples:"
    echo "  ssha s1                      - shell as s1 on $DEFAULT_HOST"
    echo "  ssha cx10                    - shell as cx10 on $DEFAULT_HOST"
    echo "  ssha -h 10.223.0.111 s1      - shell as s1 on 10.223.0.111"
    echo "  ssha s1 ls /tmp              - run a command"
    exit 1
}

check_network() {
    local host="$1"
    if ! python3 -c "
import ipaddress, subprocess, sys
host = ipaddress.ip_address(sys.argv[1])
out = subprocess.check_output(['ip', '-4', '-o', 'addr', 'show'], text=True)
for line in out.splitlines():
    parts = line.split()
    for p in parts:
        if '/' in p:
            try:
                net = ipaddress.ip_network(p, strict=False)
                if host in net:
                    sys.exit(0)
            except ValueError:
                pass
sys.exit(1)
" "$host"; then
        echo "Not on the same network as $host — make sure this computer is on that network." >&2
        exit 1
    fi
}

find_existing_keys() {
    local keys=()
    for f in "$HOME/.ssh/"*; do
        [[ -f "$f" && ! "$f" == *.pub && ! "$f" == *known_hosts* ]] || continue
        # Verify it's actually a private key
        head -1 "$f" 2>/dev/null | grep -q "PRIVATE KEY" && keys+=("$f")
    done
    echo "${keys[@]}"
}

generate_key_path() {
    local base="$HOME/.ssh/ssha_ed25519"
    local path="$base"
    local i=2
    while [ -f "$path" ]; do
        path="${base}_${i}"
        ((i++))
    done
    echo "$path"
}

setup_config() {
    mkdir -p "$CONFIG_DIR"

    local key_output
    key_output="$(find_existing_keys)"
    local keys=()
    if [ -n "$key_output" ]; then
        read -ra keys <<< "$key_output"
    fi

    echo "" >&2
    echo "First-time setup: ssha needs an SSH key to connect to devices." >&2
    echo "" >&2

    if [ ${#keys[@]} -gt 0 ]; then
        echo "Found existing SSH keys:" >&2
        for i in "${!keys[@]}"; do
            echo "  $((i+1))) ${keys[$i]}" >&2
            ssh-keygen -l -f "${keys[$i]}" 2>/dev/null | sed 's/^/      /' >&2
        done
        echo "  $((${#keys[@]}+1))) Generate a new key" >&2
        echo "" >&2
        read -rp "Which key should ssha use? [$((${#keys[@]}+1))]: " choice
        choice="${choice:-$((${#keys[@]}+1))}"
        if [ "$choice" -le "${#keys[@]}" ] 2>/dev/null; then
            printf '{"key":"%s"}\n' "${keys[$((choice-1))]}" > "$CONFIG"
            echo "Saved. ssha will use ${keys[$((choice-1))]}" >&2
            return
        fi
    fi

    local key_path
    key_path="$(generate_key_path)"
    echo "Generating a new SSH key at $key_path..." >&2
    ssh-keygen -t ed25519 -f "$key_path" -N "" -C "ssha" >&2
    printf '{"key":"%s"}\n' "$key_path" > "$CONFIG"
    echo "Saved. ssha will use $key_path" >&2
}

get_key() {
    if [ ! -f "$CONFIG" ]; then
        setup_config >&2
    fi
    python3 -c "import json,sys;print(json.load(open(sys.argv[1]))['key'])" "$CONFIG"
}

copy_key() {
    local user="$1" host="$2"
    echo "Key not authorized on $user@$host, copying (password required once)..." >&2
    ssh-copy-id -i "$KEY" "${SSH_OPTS[@]}" -o NumberOfPasswordPrompts=1 "$user@$host"
}

HOST="$DEFAULT_HOST"
USER=""

while [ $# -gt 0 ]; do
    case "$1" in
        -u|--user) USER="$2"; shift 2 ;;
        -h|--host) HOST="$2"; shift 2 ;;
        --setup) rm -f "$CONFIG"; setup_config; exit 0 ;;
        --help) usage ;;
        -*) echo "Unknown option: $1"; usage ;;
        *)
            [ -z "$USER" ] && USER="$1" && shift && break
            break ;;
    esac
done

[ -z "$USER" ] && usage

check_network "$HOST"
KEY="$(get_key)"

if ! ssh -i "$KEY" "${SSH_OPTS[@]}" -o BatchMode=yes -o ConnectTimeout=5 "$USER@$HOST" true 2>/dev/null; then
    copy_key "$USER" "$HOST"
fi

if [ $# -eq 0 ]; then
    exec ssh -i "$KEY" "${SSH_OPTS[@]}" "$USER@$HOST"
else
    exec ssh -i "$KEY" "${SSH_OPTS[@]}" "$USER@$HOST" "$@"
fi
