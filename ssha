#!/usr/bin/env bash
set -euo pipefail

DEFAULT_HOST="192.168.144.111"
CONFIG_DIR="$HOME/.config/ssha"
CONFIG="$CONFIG_DIR/config.json"
SSH_OPTS=(-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR)

usage() {
    echo "Usage: ssha [options] <user> [command...]"
    echo ""
    echo "Options:"
    echo "  -u, --user <user>   SSH user"
    echo "  -h, --host <host>   Host IP (default: $DEFAULT_HOST)"
    echo ""
    echo "Examples:"
    echo "  ssha s1                      - shell as s1 on $DEFAULT_HOST"
    echo "  ssha cx10                    - shell as cx10 on $DEFAULT_HOST"
    echo "  ssha -h 10.223.0.111 s1      - shell as s1 on 10.223.0.111"
    echo "  ssha s1 ls /tmp              - run a command"
    exit 1
}

check_network() {
    local host="$1"
    if ! python3 -c "
import ipaddress, subprocess, sys
host = ipaddress.ip_address(sys.argv[1])
out = subprocess.check_output(['ip', '-4', '-o', 'addr', 'show'], text=True)
for line in out.splitlines():
    parts = line.split()
    for p in parts:
        if '/' in p:
            try:
                net = ipaddress.ip_network(p, strict=False)
                if host in net:
                    sys.exit(0)
            except ValueError:
                pass
sys.exit(1)
" "$host"; then
        echo "Not on the same network as $host — make sure this computer is on that network."
        exit 1
    fi
}

find_existing_keys() {
    local keys=()
    for candidate in "$HOME/.ssh/id_ed25519" "$HOME/.ssh/id_rsa" "$HOME/.ssh/id_ecdsa"; do
        [ -f "$candidate" ] && keys+=("$candidate")
    done
    echo "${keys[@]}"
}

setup_config() {
    mkdir -p "$CONFIG_DIR"

    read -ra keys <<< "$(find_existing_keys)"

    if [ ${#keys[@]} -gt 1 ]; then
        echo "Found multiple SSH keys:"
        for i in "${!keys[@]}"; do
            echo "  $((i+1))) ${keys[$i]}"
        done
        echo "  $((${#keys[@]}+1))) Generate a new key"
        read -rp "Choose [1]: " choice
        choice="${choice:-1}"
        if [ "$choice" -le "${#keys[@]}" ] 2>/dev/null; then
            printf '{"key":"%s"}\n' "${keys[$((choice-1))]}" > "$CONFIG"
            return
        fi
    elif [ ${#keys[@]} -eq 1 ]; then
        echo "Found existing SSH key: ${keys[0]}"
        read -rp "Use this key? [Y/n] " choice
        if [[ -z "$choice" || "$choice" =~ ^[Yy] ]]; then
            printf '{"key":"%s"}\n' "${keys[0]}" > "$CONFIG"
            return
        fi
    fi

    key_path="$HOME/.ssh/ssha_ed25519"
    echo "Generating new key at $key_path..."
    ssh-keygen -t ed25519 -f "$key_path" -N "" -C "ssha-airolit"
    printf '{"key":"%s"}\n' "$key_path" > "$CONFIG"
}

get_key() {
    if [ ! -f "$CONFIG" ]; then
        setup_config
    fi
    python3 -c "import json,sys;print(json.load(open(sys.argv[1]))['key'])" "$CONFIG"
}

copy_key() {
    local user="$1" host="$2"
    echo "Key not authorized on $user@$host, copying (password required once)..."
    ssh-copy-id -i "$KEY" "${SSH_OPTS[@]}" "$user@$host"
}

HOST="$DEFAULT_HOST"
USER=""

while [ $# -gt 0 ]; do
    case "$1" in
        -u|--user) USER="$2"; shift 2 ;;
        -h|--host) HOST="$2"; shift 2 ;;
        --help) usage ;;
        -*) echo "Unknown option: $1"; usage ;;
        *)
            [ -z "$USER" ] && USER="$1" && shift && break
            break ;;
    esac
done

[ -z "$USER" ] && usage

check_network "$HOST"
KEY="$(get_key)"

if ! ssh -i "$KEY" "${SSH_OPTS[@]}" -o BatchMode=yes -o ConnectTimeout=5 "$USER@$HOST" true 2>/dev/null; then
    copy_key "$USER" "$HOST"
fi

if [ $# -eq 0 ]; then
    exec ssh -i "$KEY" "${SSH_OPTS[@]}" "$USER@$HOST"
else
    exec ssh -i "$KEY" "${SSH_OPTS[@]}" "$USER@$HOST" "$@"
fi
